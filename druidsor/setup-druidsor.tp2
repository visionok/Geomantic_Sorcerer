// spells from iwdee/iwdification/scs
OUTER_SET check = IDS_OF_SYMBOL(spell CLERIC_SMASHING_WAVE)
ACTION_IF check > 0 BEGIN // clone spell if present 

  LAF RES_NUM_OF_SPELL_NAME STR_VAR spell_name = CLERIC_SMASHING_WAVE RET spell_res END // get resource
  LAF cd_clone_spell_bulk INT_VAR make_arcane = 1 STR_VAR source = ~%spell_res%~ destination = ~ca#dstce~ RET_ARRAY cd_clone_spell_array END

END ELSE BEGIN   

  COPY  ~druidsor/SPLs/CA#DSTCE.spl~  ~override/CA#DSTCE.spl~ // smashing wave
      SAY NAME1 @307
      SAY NAME2 @307
      LPF ALTER_HEADER INT_VAR projectile = ~%CA#WAVE%~ END 
      
END 

OUTER_SET check = IDS_OF_SYMBOL(spell CLERIC_WHIRLWIND)
ACTION_IF check > 0 BEGIN // clone spell if present 

  LAF RES_NUM_OF_SPELL_NAME STR_VAR spell_name = CLERIC_WHIRLWIND RET spell_res END // get resource
  LAF cd_clone_spell_bulk INT_VAR make_arcane = 1 STR_VAR source = ~%spell_res%~ destination = ~ca#dstck~ RET_ARRAY cd_clone_spell_array END

END ELSE BEGIN   

COPY  ~druidsor/SPLs/CA#DSTCK.spl~  ~override/CA#DSTCK.spl~ // whirlwind
    SAY NAME1 @303
    SAY NAME2 @303
      
END 

