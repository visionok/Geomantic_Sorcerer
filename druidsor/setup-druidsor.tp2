BACKUP   ~weidu_external/druidsor/backup~    // location to store files for uninstall purposes
SUPPORT  ~https://www.gibberlings3.net/forums/forum/28-miscellaneous-released-mods/~ // URL displayed if install fails

ALWAYS

  ACTION_IF ((FILE_EXISTS ~dlc/sod-dlc.zip~) OR (FILE_EXISTS ~sod-dlc.zip~)) THEN BEGIN FAIL @3 END // Modmerge check

  ACTION_IF !VARIABLE_IS_SET druidsor_always THEN BEGIN // check to make this happen only once per install

    OUTER_SET druidsor_always = 1
    OUTER_SET enhanced_edition = 0
    OUTER_SPRINT tra_path ~druidsor/languages~

    ACTION_IF GAME_IS ~bgee iwdee bg2ee eet~ BEGIN

      OUTER_SET enhanced_edition = 1
      OUTER_SPRINT tra_path ~weidu_external/druidsor/languages~

      // convert strings to UTF-8 for BGEE/BG2EE
      ACTION_DEFINE_ARRAY cdreload BEGIN setup END
      LAF HANDLE_CHARSETS INT_VAR infer_charsets = 1 STR_VAR tra_path = ~druidsor/languages~ out_path = ~weidu_external/druidsor/languages~ reload_array = cdreload END

    END
    
  END  

END

VERSION ~v7~
README ~druidsor/readme-druidsor.html~ // Offer to display the main readme

ASK_EVERY_COMPONENT

LANGUAGE ~English~
         ~english~
         ~druidsor/languages/english/setup.tra~ // English
LANGUAGE ~Francais (Translation by zooloo of the D'Oghmatiques)~
         ~french~
         ~druidsor/languages/english/setup.tra~ // English
         ~druidsor/languages/french/setup.tra~ // French
LANGUAGE ~Spanish (Translation by lisandro)~
         ~spanish~
         ~druidsor/languages/english/setup.tra~ // English
         ~druidsor/languages/spanish/setup.tra~ // spanish

